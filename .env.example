# Copy this file to `.env` and fill in. .env is git-ignored.

# Gmail SMTP password — generate at https://myaccount.google.com/apppasswords
# (requires 2FA on the account). Paste the 16-char app password here.
SMTP_PASSWORD=your_gmail_app_password_here

# Elsevier API access for ScienceDirect PDFs (Elsevier journals: AgrForMet,
# Field Crops Research, Geoderma, Soil & Tillage, Water Research, Soil Biol
# Biochem, One Earth — all 10.1016/* DOIs).
#
# Step 1: Register free at https://dev.elsevier.com/ → Create API Key.
#         A FREE key alone returns only a 1-page teaser (cover/abstract). The
#         downloader detects this and rejects it so the cache stays clean.
#
# Step 2: Get an institutional Insttoken from UIUC library e-resources team:
#           https://www.library.illinois.edu/ → contact a science librarian
#           OR send an Elsevier API support request and ask them to associate
#           your key with the UIUC institution. With Insttoken set, the API
#           returns full-text PDFs.
#
# If only ELSEVIER_API_KEY is set (no Insttoken), the downloader will try the
# API once per Elsevier paper, get the teaser, and fall back to abstract-only.
ELSEVIER_API_KEY=your_elsevier_api_key_here
ELSEVIER_INSTTOKEN=
